region = "us-east-1"

project_name = "tienda-virtual"
environment  = "main"

id_cuenta_aws       = "123456789012"
nombre_rol_iam      = "LabRole"
path_base_servicio  = "api"
nombre_cluster_ecs  = "tienda-virtual-cluster"
familia_tarea_ecs   = "tienda-virtual"
nombre_repo_ecr     = "tienda-virtual"
host_base_datos     = "mysql.example.us-east-1.rds.amazonaws.com"
nombre_base_datos   = "tienda_virtual"
usuario_base_datos  = "admin"
contrasenha_base_datos = "cambiar-en-tu-tfvars-local"
nombre_servicio_ecs = "tienda-virtual-servicio"

# Mantienen compatibilidad con los recursos existentes. Cambiarlos crea recursos nuevos.
nombre_load_balancer = "tienda-virtual-alb"
nombre_target_group  = "tg-tienda-virtual"
nombre_event_bus     = "ordenes-bus"

# Recomendado cuando no quieres depender de la VPC por defecto.
# Las subnets deben ser publicas y pertenecer al menos a dos AZs distintas.
# vpc_id = "vpc-xxxxxxxxxxxxxxxxx"
# public_subnet_ids = [
#   "subnet-xxxxxxxxxxxxxxxxx",
#   "subnet-yyyyyyyyyyyyyyyyy",
# ]

# Alternativa para AWS Academy/Learner Lab cuando la VPC por defecto solo tiene una subnet.
# Valida primero que el CIDR esté dentro de la VPC y no se solape con subnets existentes.
# create_missing_public_subnet_for_alb       = true
# additional_public_subnet_cidr_block        = "172.31.32.0/20"
# additional_public_subnet_availability_zone = "us-east-1b"
